{
  "name": "almost-control",
  "version": "6.0.14",
  "description": "Almost98 Control Panel",
  "main": "main.js",
  "scripts": {
    "start": "set ELECTRON_RUN_AS_NODE=& electron .",
    "general:start": "npm --prefix general-control run start",
    "build": "electron-builder --win --x64",
    "publish": "electron-builder --win --x64 --publish always"
  },
  "build": {
    "appId": "com.almost98.control",
    "productName": "Almost - Panel de control",
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": true,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "shortcutName": "Almost - Panel de control"
    },
    "files": [
      "**/*",
      "!node_modules/.cache"
    ],
    "publish": {
      "provider": "github",
      "owner": "Dieqoz",
      "repo": "almost-control-panel"
    }
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.39.0",
    "electron-updater": "^6.3.9",
    "obs-websocket-js": "^5.0.8",
    "uiohook-napi": "^1.5.4",
    "vban": "^1.5.6",
    "voicemeeter-connector": "^2.2.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.13.3"
  }
}
